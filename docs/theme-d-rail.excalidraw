      "isDeleted": false,
      "boundElements": null,
      "updated": 1780120584846,
      "link": null,
      "locked": false,
      "text": "(ii) 「rail」 — WS が横一列 + 中央プレビュー（ホットキーで召喚）",
      "fontSize": 17,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "(ii) 「rail」 — WS が横一列 + 中央プレビュー（ホットキーで召喚）",
      "autoResize": true,
      "lineHeight": 1.15,
      "syncedAt": "2026-05-30T06:00:41.204Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-05-30T06:00:41.195Z"
    },
    {
      "id": "mprwbza6zipbfvtjj7",
      "type": "text",
      "x": 104,
      "y": 178,
      "width": 735.09423828125,
      "height": 13.799999999999999,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
