      "isDeleted": false,
      "boundElements": null,
      "updated": 1780120584845,
      "link": null,
      "locked": false,
      "text": "② もし常設なら：下が隠れる ✗（今回はやらない）",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "② もし常設なら：下が隠れる ✗（今回はやらない）",
      "autoResize": true,
      "lineHeight": 1.15,
      "syncedAt": "2026-05-30T06:00:41.204Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-05-30T06:00:41.195Z"
    },
    {
      "id": "mprwbza6hig4feww95",
      "type": "text",
      "x": 968,
      "y": 1180,
      "width": 250.61181640625,
      "height": 14.95,
      "angle": 0,
      "strokeColor": "#adb5bd",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
