      "isDeleted": false,
      "boundElements": null,
      "updated": 1780120584846,
      "link": null,
      "locked": false,
      "text": "③ 常設にするなら予約が要る（今回不要）",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "③ 常設にするなら予約が要る（今回不要）",
