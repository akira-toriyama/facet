      "isDeleted": false,
      "boundElements": null,
      "updated": 1780120584846,
      "link": null,
      "locked": false,
      "text": "→ むしろ Grid の「召喚 / Esc で閉じる」仕組みをそのまま流用できる ＝ さらに作りやすい。",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "→ むしろ Grid の「召喚 / Esc で閉じる」仕組みをそのまま流用できる ＝ さらに作りやすい。",
      "autoResize": true,
      "lineHeight": 1.15,
      "syncedAt": "2026-05-30T06:00:41.204Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-05-30T06:00:41.195Z"
    },
    {
      "id": "mprwbza6hqjxcqe5ccb",
      "type": "text",
      "x": 104,
      "y": 148,
      "width": 515.1962890625,
      "height": 19.549999999999997,
      "angle": 0,
      "strokeColor": "#0ca678",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
