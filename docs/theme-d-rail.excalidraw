      "isDeleted": false,
      "boundElements": null,
      "updated": 1780120584846,
      "link": null,
      "locked": false,
      "text": "ホットキーで召喚→WSを横一列表示。ホバー→中央に大きくプレビュー→操作したら閉じる。≒ Mission Control / Win11 タスクビュー。",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ホットキーで召喚→WSを横一列表示。ホバー→中央に大きくプレビュー→操作したら閉じる。≒ Mission Control / Win11 タスクビュー。",
      "autoResize": true,
      "lineHeight": 1.15,
      "syncedAt": "2026-05-30T06:00:41.204Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-05-30T06:00:41.195Z"
    },
