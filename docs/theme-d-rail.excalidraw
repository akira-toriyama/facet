      "isDeleted": false,
      "boundElements": null,
      "updated": 1780120584845,
      "link": null,
      "locked": false,
      "text": "① facetの通常：画面フルにタイル",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "① facetの通常：画面フルにタイル",
