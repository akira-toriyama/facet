    },
    {
      "id": "mprwbza645p6na4le9t",
      "type": "text",
      "x": 104,
      "y": 1446,
      "width": 546.736328125,
      "height": 14.95,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
