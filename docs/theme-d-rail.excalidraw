      "syncedAt": "2026-05-30T06:00:41.204Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-05-30T06:00:41.195Z"
    },
    {
      "id": "mprwbza6fel40zarug",
      "type": "text",
      "x": 548,
      "y": 1180,
      "width": 300.64404296875,
      "height": 14.95,
      "angle": 0,
      "strokeColor": "#adb5bd",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
