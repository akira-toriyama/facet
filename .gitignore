# SwiftPM
.build/
.swiftpm/
# Package.resolved IS tracked (not ignored): facet is an executable with an
# external dependency (sill), so the lockfile is committed for reproducible
# CI builds + Dependabot version tracking.
*.xcodeproj/
*.xcworkspace/

# macOS
.DS_Store
*.swp

# App bundles produced by local build scripts
*.app/

# Code signing
.signing-id

# Logs (local dev)
/tmp/*.log

# Claude Code per-session scheduled-tasks lock (transient harness state;
# the rest of .claude/ — settings, commands — can still be committed)
.claude/scheduled_tasks.lock
