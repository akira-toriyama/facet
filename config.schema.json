            "catppuccin-latte",
            "system",
            "random"
          ],
          "type" : "string"
        }
      },
      "type" : "object"
    },
    "tree" : {
      "additionalProperties" : false,
      "properties" : {
        "height" : {
          "description" : "Panel seed height (px).",
          "type" : "integer"
        },
        "line-pets" : {
          "description" : "Arcade pets walking the panel border; `[]` = off.",
          "items" : {
            "enum" : [
              "chomp",
              "ghost"
            ],
            "type" : "string"
