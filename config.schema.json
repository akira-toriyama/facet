{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "additionalProperties" : false,
  "properties" : {
    "animation" : {
      "additionalProperties" : false,
      "properties" : {
        "curve" : {
          "default" : "cubic",
          "description" : "Easing curve.",
          "enum" : [
            "cubic",
            "spring",
            "silky",
            "snappy",
            "random"
          ],
          "type" : "string"
        },
        "duration-ms" : {
          "description" : "Slide duration (ms). Unset = per-curve default.",
          "maximum" : 800,
          "minimum" : 80,
          "type" : "integer"
        },
        "enabled" : {
          "default" : false,
          "description" : "Animate window-geometry transitions (opt-in).",
          "type" : "boolean"
        },
        "event-driven" : {
          "default" : true,
          "description" : "Also animate window open/close reflow.",
          "type" : "boolean"
        }
      },
      "type" : "object"
    },
    "border" : {
      "additionalProperties" : false,
      "description" : "Tree-panel border effect.",
      "properties" : {
        "color-cycle-ms" : {
          "description" : "Border animation period (ms).",
          "maximum" : 120000,
          "minimum" : 1000,
          "type" : "integer"
        },
        "effect" : {
          "default" : "off",
          "enum" : [
            "neon",
            "cyber",
            "vapor",
            "kawaii",
            "rainbow",
            "chomp",
            "random",
            "off"
          ],
          "type" : "string"
        },
        "glow" : {
          "default" : true,
          "description" : "Neon bloom under the stroke.",
          "type" : "boolean"
        },
        "max-width" : {
          "description" : "Width-breathing ceil.",
          "maximum" : 30,
          "minimum" : 0.5,
          "type" : "number"
        },
        "min-width" : {
          "description" : "Width-breathing floor (set with max-width).",
          "maximum" : 30,
          "minimum" : 0.5,
          "type" : "number"
        },
        "width" : {
          "default" : 1.5,
          "maximum" : 30,
          "minimum" : 0.5,
          "type" : "number"
        }
      },
      "type" : "object"
    },
    "default-view" : {
      "description" : "Panel shown at launch; unset = agent-only (no panel).",
      "enum" : [
        "tree",
        "grid"
      ],
      "type" : "string"
    },
    "desktop" : {
      "additionalProperties" : true,
      "description" : "`[[desktop.N.section]]` ordered per-mac-desktop display sections (N = Mission Control ordinal) — the sole way to configure a mac desktop. Each has a required `type` of workspace / lens / unassigned: workspace = `{ type, layout }` (auto-named spatial cell — workspaces are not named from config); lens = `{ type, label, match, layout, apply }` where match = a facet filter WHERE-clause, layout = the stateless tiling engine for the cross-workspace union (spiral default; bsp / stack clamp to the [layout] default), and apply = `{ workspace, tags = [], floating, sticky, master }` set on a window routed in. (unassigned = `{ type, label }` still decodes but is DEFERRED/emits nothing — the EX-3 迷子/orphan receptacle is just a lens with `match = 'not workspace'`.) Array order = tree display order. Any section block makes facet opt-in (manages only configured desktops).",
      "type" : "object"
    },
    "exclude" : {
      "items" : {
        "additionalProperties" : false,
        "description" : "Windows matching a rule are floated/ignored, not tiled.",
        "properties" : {
          "action" : {
            "default" : "float",
            "enum" : [
              "float",
              "ignore",
              "manage"
            ],
            "type" : "string"
          },
          "app" : {
            "description" : "App-name regex (substring unless anchored).",
            "type" : "string"
          },
          "max-height" : {
            "type" : "integer"
          },
          "max-width" : {
            "type" : "integer"
          },
          "role" : {
            "description" : "AX role (exact).",
            "type" : "string"
          },
          "subrole" : {
            "description" : "AX subrole (exact).",
            "type" : "string"
          },
          "title" : {
            "description" : "Title regex.",
            "type" : "string"
          }
        },
        "type" : "object"
      },
      "type" : "array"
    },
    "grid" : {
      "additionalProperties" : false,
      "properties" : {
        "cols" : {
          "default" : 4,
          "maximum" : 12,
          "minimum" : 1,
          "type" : "integer"
        },
        "label-position" : {
          "default" : "up",
          "enum" : [
            "up",
            "down"
          ],
          "type" : "string"
        },
        "theme" : {
          "default" : "",
          "description" : "Per-view theme; `\"\"` inherits `[theme].name`.",
          "enum" : [
            "terminal",
            "chomp",
            "rainbow",
            "cobalt2",
            "shades-of-purple",
            "tokyo-hack",
            "github-dark",
            "dracula",
            "catppuccin-mocha",
            "gruvbox",
            "github-light",
            "catppuccin-latte",
            "system",
            "random",
            ""
          ],
          "type" : "string"
        },
        "thumbnail-refresh-seconds" : {
          "default" : 4,
          "description" : "Background thumbnail capture interval; 0 disables.",
          "maximum" : 60,
          "minimum" : 0,
          "type" : "integer"
        }
      },
      "type" : "object"
    },
    "layout" : {
      "additionalProperties" : false,
      "properties" : {
        "default" : {
          "default" : "float",
          "description" : "Startup layout: float | bsp | stack | a registered engine.",
          "type" : "string"
        },
        "inner-gap" : {
          "default" : 0,
          "description" : "Gap between adjacent tiled windows (px).",
          "maximum" : 1000,
          "minimum" : 0,
          "type" : "integer"
        },
        "outer-gap" : {
          "default" : 0,
          "description" : "Inset from screen edges (px); per-edge keys override.",
          "maximum" : 1000,
          "minimum" : 0,
          "type" : "integer"
        },
        "outer-gap-bottom" : {
          "maximum" : 1000,
          "minimum" : 0,
          "type" : "integer"
        },
        "outer-gap-left" : {
          "maximum" : 1000,
          "minimum" : 0,
          "type" : "integer"
        },
        "outer-gap-right" : {
          "maximum" : 1000,
          "minimum" : 0,
          "type" : "integer"
        },
        "outer-gap-top" : {
          "maximum" : 1000,
          "minimum" : 0,
          "type" : "integer"
        },
        "smart-gaps" : {
          "default" : false,
          "description" : "Drop the outer gap for a lone tiled window.",
          "type" : "boolean"
        }
      },
      "type" : "object"
    },
    "rail" : {
      "additionalProperties" : false,
      "properties" : {
        "cells" : {
          "default" : 7,
          "description" : "Max strip cells shown at once.",
          "maximum" : 20,
          "minimum" : 1,
          "type" : "integer"
        },
        "edge" : {
          "default" : "bottom",
          "description" : "Screen edge the rail docks against.",
          "enum" : [
            "top",
            "bottom",
            "left",
            "right"
          ],
          "type" : "string"
        },
        "strip" : {
          "default" : 30,
          "description" : "Strip band size, % of the short screen edge.",
          "maximum" : 50,
          "minimum" : 8,
          "type" : "integer"
        },
        "theme" : {
          "default" : "",
          "description" : "Per-view theme; `\"\"` inherits `[theme].name`.",
          "enum" : [
            "terminal",
            "chomp",
            "rainbow",
            "cobalt2",
            "shades-of-purple",
            "tokyo-hack",
            "github-dark",
            "dracula",
            "catppuccin-mocha",
            "gruvbox",
            "github-light",
            "catppuccin-latte",
            "system",
            "random",
            ""
          ],
          "type" : "string"
        }
      },
      "type" : "object"
    },
    "theme" : {
      "additionalProperties" : false,
      "description" : "App-default palette.",
      "properties" : {
        "color-cycle-ms" : {
          "description" : "Accent-rotation period for animated themes (ms). Unset = static.",
          "maximum" : 120000,
          "minimum" : 1000,
          "type" : "integer"
        },
        "name" : {
          "default" : "terminal",
          "description" : "Theme name (sill catalog); `random` picks one per launch.",
          "enum" : [
            "terminal",
            "chomp",
            "rainbow",
            "cobalt2",
            "shades-of-purple",
            "tokyo-hack",
            "github-dark",
            "dracula",
            "catppuccin-mocha",
            "gruvbox",
            "github-light",
            "catppuccin-latte",
            "system",
            "random"
          ],
          "type" : "string"
        }
      },
      "type" : "object"
    },
    "tree" : {
      "additionalProperties" : false,
      "properties" : {
        "height" : {
          "description" : "Panel seed height (px).",
          "type" : "integer"
        },
        "line-pets" : {
          "description" : "Arcade pets walking the panel border; `[]` = off.",
          "items" : {
            "enum" : [
              "chomp",
              "ghost"
            ],
            "type" : "string"
          },
          "type" : "array"
        },
        "pet-lap-seconds" : {
          "default" : 8,
          "description" : "Seconds for a pet to circle a row once.",
          "minimum" : 0.5,
          "type" : "number"
        },
        "pet-scale" : {
          "default" : 0.90000000000000002,
          "description" : "Pet size multiplier.",
          "minimum" : 0.10000000000000001,
          "type" : "number"
        },
        "pos-x" : {
          "description" : "Panel seed X (top-left origin, px). All four needed.",
          "type" : "integer"
        },
        "pos-y" : {
          "description" : "Panel seed Y (top-left origin, px).",
          "type" : "integer"
        },
        "preview-mode" : {
          "default" : "popover",
          "description" : "How the hover preview is sized/placed.",
          "enum" : [
            "popover",
            "mirror"
          ],
          "type" : "string"
        },
        "theme" : {
          "default" : "",
          "description" : "Per-view theme; `\"\"` inherits `[theme].name`.",
          "enum" : [
            "terminal",
            "chomp",
            "rainbow",
            "cobalt2",
            "shades-of-purple",
            "tokyo-hack",
            "github-dark",
            "dracula",
            "catppuccin-mocha",
            "gruvbox",
            "github-light",
            "catppuccin-latte",
            "system",
            "random",
            ""
          ],
          "type" : "string"
        },
        "width" : {
          "description" : "Panel seed width (px).",
          "type" : "integer"
        }
      },
      "type" : "object"
    },
    "window" : {
      "additionalProperties" : false,
      "properties" : {
        "raise-on-open" : {
          "default" : "raise",
          "description" : "How a freshly-opened floating window is surfaced.",
          "enum" : [
            "raise",
            "activate",
            "off"
          ],
          "type" : "string"
        }
      },
      "type" : "object"
    }
  },
  "title" : "facet config.toml",
  "type" : "object"
}
