{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "additionalProperties" : false,
  "properties" : {
    "animation" : {
      "additionalProperties" : false,
      "properties" : {
        "curve" : {
          "default" : "cubic",
          "description" : "Easing curve.",
          "enum" : [
            "cubic",
            "spring",
            "silky",
            "snappy",
            "random"
          ],
          "type" : "string"
        },
        "duration-ms" : {
          "description" : "Slide duration (ms). Unset = per-curve default.",
          "maximum" : 800,
          "minimum" : 80,
          "type" : "integer"
        },
        "enabled" : {
          "default" : false,
          "description" : "Animate window-geometry transitions (opt-in).",
          "type" : "boolean"
        },
        "event-driven" : {
          "default" : true,
          "description" : "Also animate window open/close reflow.",
          "type" : "boolean"
        }
      },
      "type" : "object"
    },
    "border" : {
      "additionalProperties" : false,
      "description" : "Tree-panel border effect.",
      "properties" : {
        "color-cycle-ms" : {
          "description" : "Border animation period (ms).",
          "maximum" : 120000,
          "minimum" : 1000,
          "type" : "integer"
        },
        "effect" : {
          "default" : "off",
          "enum" : [
            "neon",
            "cyber",
            "vapor",
            "kawaii",
            "rainbow",
            "chomp",
            "voltage",
            "toxic",
            "ember",
            "solar-veil",
            "molten-vein",
            "coin-op",
            "arcane",
            "biolume",
            "midas",
            "spectre",
            "random",
            "off"
          ],
          "type" : "string"
        },
        "glow" : {
          "default" : true,
          "description" : "Neon bloom under the stroke.",
          "type" : "boolean"
        },
        "max-width" : {
          "description" : "Width-breathing ceil.",
          "maximum" : 30,
          "minimum" : 0.5,
          "type" : "number"
        },
        "min-width" : {
          "description" : "Width-breathing floor (set with max-width).",
          "maximum" : 30,
          "minimum" : 0.5,
          "type" : "number"
        },
        "width" : {
          "default" : 1.5,
          "maximum" : 30,
          "minimum" : 0.5,
          "type" : "number"
        }
      },
      "type" : "object"
    },
    "config" : {
      "additionalProperties" : false,
      "description" : "Config auto-persistence (session edits → config.toml, no UI). See CLAUDE.md `### Configuration`.",
      "properties" : {
        "auto-promote" : {
          "default" : false,
          "description" : "Promote a NEWER snapshot onto config.toml at startup (overwrite + load) — the one sanctioned write to your config file. A hand-edit between sessions still wins (mtime guard). Off by default.",
          "type" : "boolean"
        },
        "export-path" : {
          "description" : "Auto-export snapshot target. Set = ON: every session edit (rename / isolate match / layout / tag vocab) writes the full effective config here, surgically — config.toml is left untouched. MUST be a different file from config.toml. `~` and config-dir-relative paths resolve.",
          "type" : "string"
        }
      },
      "type" : "object"
    },
    "desktop" : {
      "additionalProperties" : false,
      "description" : "`[desktop.N]` configures one mac desktop (N = Mission Control ordinal) — a SINGLE TYPED table: `type` is workspace / isolate (omitted = workspace). A `workspace` desktop carries ordered `[[desktop.N.section]]` rows; array order = tree display order. Each row is a workspace SPATIAL cell `{ label, layout }` — an optional `label` names it, else it shows its 1-based index; membership changes via DnD / `facet window --move-to N` (sections have NO `type` / `match` / `apply` — a stray one fails --validate). EVERY row is a workspace cell — the `unassigned = true` lost-and-found MARKER was retired (t-6rbc: nothing could put a window in it, so it could only ever be an empty section). An `isolate` desktop writes `match` (REQUIRED — a facet-filter WHERE-clause) plus `layout` / `show-non-matching` / `label` directly on the `[desktop.N]` table and declares NO sections: while that mac desktop is active facet ALWAYS tiles the matched windows with `layout` and anchor-parks the rest. An isolate desktop is TREE-ONLY (`--view grid` / `--view rail` loud-reject there). Any `[desktop.N]` or `[[desktop.N.section]]` block makes facet opt-in — it then manages ONLY the configured mac desktops.",
      "patternProperties" : {
        "^0*[1-9][0-9]*$" : {
          "additionalProperties" : false,
          "description" : "One mac desktop (N = Mission Control ordinal): its `type`/`label`, plus its display sections.",
          "properties" : {
            "label" : {
              "description" : "Display name for this mac desktop.",
              "type" : "string"
            },
            "layout" : {
              "description" : "isolate desktop only — layout-engine name for the matched windows.",
              "type" : "string"
            },
            "match" : {
              "description" : "isolate desktop only — a facet-filter WHERE-clause selecting the tiled windows. Everything it does not select is anchor-parked off-screen.",
              "type" : "string"
            },
            "section" : {
              "items" : {
                "additionalProperties" : false,
                "description" : "One workspace spatial cell.",
                "properties" : {
                  "label" : {
                    "description" : "Display name; unset shows the section's 1-based index.",
                    "type" : "string"
                  },
                  "layout" : {
                    "description" : "Layout-engine name for this workspace cell.",
                    "type" : "string"
                  }
                },
                "type" : "object"
              },
              "type" : "array"
            },
            "show-non-matching" : {
              "description" : "isolate desktop only — also show the parked non-matching windows as a second tree section (the `holding` section). They are parked either way; this only decides whether the tree lists them.",
              "type" : "boolean"
            },
            "type" : {
              "description" : "workspace = spatial sections you file windows into (tree/grid/rail); isolate = membership comes from `match`: facet tiles the matched windows with `layout` and ANCHOR-PARKS the rest, for as long as you are on that desktop (tree only).",
              "enum" : [
                "workspace",
                "isolate"
              ],
              "type" : "string"
            }
          },
          "type" : "object"
        }
      },
      "type" : "object"
    },
    "exclude" : {
      "items" : {
        "additionalProperties" : false,
        "description" : "Windows matching a rule are floated/ignored, not tiled.",
        "properties" : {
          "action" : {
            "default" : "float",
            "enum" : [
              "float",
              "ignore",
              "manage"
            ],
            "type" : "string",
            "x-taplo" : {
              "docs" : {
                "enumValues" : [
                  "Float it: still tracked + shown in the tree, just not tiled (default).",
                  "Drop it entirely: never enters a workspace, never shown.",
                  "Force-tile it even though the allowlist would otherwise float/ignore it."
                ]
              }
            }
          },
          "app" : {
            "description" : "App-name regex (substring unless anchored).",
            "type" : "string"
          },
          "max-height" : {
            "type" : "integer"
          },
          "max-width" : {
            "type" : "integer"
          },
          "role" : {
            "description" : "AX role (exact).",
            "type" : "string"
          },
          "subrole" : {
            "description" : "AX subrole (exact).",
            "type" : "string"
          },
          "title" : {
            "description" : "Title regex.",
            "type" : "string"
          }
        },
        "type" : "object"
      },
      "type" : "array"
    },
