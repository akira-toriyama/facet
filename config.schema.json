            ""
          ],
          "type" : "string"
        },
        "width" : {
          "description" : "Panel seed width (px).",
          "type" : "integer"
        }
      },
      "type" : "object"
    },
    "window" : {
      "additionalProperties" : false,
      "properties" : {
        "raise-on-open" : {
          "default" : "raise",
          "description" : "How a freshly-opened floating window is surfaced.",
          "enum" : [
            "raise",
            "activate",
            "off"
          ],
          "type" : "string",
          "x-taplo" : {
            "docs" : {
              "enumValues" : [
                "Lift the float to the front of its own app, without stealing focus (default).",
                "Bring the owning app frontmost on every fresh float (steals focus each time).",
                "Do nothing — leave the float where the app placed it."
              ]
            }
          }
        }
      },
      "type" : "object"
    }
